generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  cpf          String   @unique // armazenado criptografado (AES-256-CBC)
  cpfHash      String   @default("") @map("cpf_hash") // SHA-256 para busca
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  role         String   @default("client") // "client" | "barber"
  createdAt    DateTime @default(now()) @map("created_at")
  barber       Barber?
  client       Client?

  @@map("users")
}

model Client {
  id           String        @id @default(cuid())
  userId       String        @unique @map("user_id")
  phone        String        @default("")
  points       Int           @default(0)
  favorites    String        @default("") @map("favorite_barber_ids") // JSON array de IDs
  noShowCount  Int           @default(0) @map("no_show_count")
  isBlocked    Boolean       @default(false) @map("is_blocked")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  reviews      Review[]

  @@map("clients")
}

model Barber {
  id              String         @id @default(cuid())
  userId          String         @unique @map("user_id")
  name            String
  location        String         @default("")
  slug            String         @unique
  bio             String         @default("")
  coverUrl        String         @default("") @map("cover_url")
  avatarUrl       String         @default("") @map("avatar_url")
  instagram       String         @default("")
  phone           String         @default("")
  planType        String         @default("FREE") @map("plan_type")       // FREE | BASIC | QUARTERLY | ANNUAL | FAMILY_MONTHLY | FAMILY_QUARTERLY | FAMILY_ANNUAL
  planStatus      String         @default("TRIAL") @map("plan_status")    // TRIAL | ACTIVE | EXPIRED | CANCELED
  planExpiration  DateTime?      @map("plan_expiration")
  maxStaff        Int            @default(1) @map("max_staff")
  commissionPct   Float          @default(50) @map("commission_pct")
  ownerId         String?        @map("owner_id")
  owner           Barber?        @relation("BarberStaff", fields: [ownerId], references: [id])
  staff           Barber[]       @relation("BarberStaff")
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  services        Service[]
  appointments    Appointment[]
  gallery         GalleryImage[]
  workingHours    WorkingHours[]
  scheduleBlocks  ScheduleBlock[]
  reviews         Review[]
  expenses        Expense[]

  @@map("barbers")
}

model Service {
  id              String        @id @default(cuid())
  barberId        String        @map("barber_id")
  name            String
  priceInCents    Int           @map("price_in_cents")
  durationMinutes Int           @map("duration_minutes")
  barber          Barber        @relation(fields: [barberId], references: [id], onDelete: Cascade)
  appointments    Appointment[]

  @@map("services")
}

model GalleryImage {
  id       String @id @default(cuid())
  barberId String @map("barber_id")
  url      String
  caption  String @default("")
  barber   Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@map("gallery_images")
}

model WorkingHours {
  id           String @id @default(cuid())
  barberId     String @map("barber_id")
  dayOfWeek    Int    @map("day_of_week") // 0=Dom, 1=Seg ... 6=Sab
  startTime    String @map("start_time") // "08:00"
  endTime      String @map("end_time")   // "18:00"
  breakStart   String @default("") @map("break_start") // "12:00" ou vazio
  breakEnd     String @default("") @map("break_end")   // "13:00" ou vazio
  barber       Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, dayOfWeek])
  @@map("working_hours")
}

model ScheduleBlock {
  id        String   @id @default(cuid())
  barberId  String   @map("barber_id")
  date      String   // "2025-12-25"
  startTime String?  @map("start_time") // "12:00" — bloqueio parcial de horário
  endTime   String?  @map("end_time")   // "13:00"
  reason    String   @default("")
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@map("schedule_blocks")
}

model Appointment {
  id          String   @id @default(cuid())
  barberId    String   @map("barber_id")
  serviceId   String   @map("service_id")
  clientId    String?  @map("client_id")
  clientName  String   @map("client_name")
  startsAt    DateTime @map("starts_at")
  endsAt      DateTime? @map("ends_at")  // calculado a partir de durationMinutes
  status      String   @default("pending") // pending | confirmed | completed | cancelled | no_show
  pointsAwarded Boolean @default(false) @map("points_awarded")
  createdAt   DateTime @default(now()) @map("created_at")
  barber      Barber   @relation(fields: [barberId], references: [id])
  service     Service  @relation(fields: [serviceId], references: [id])
  client      Client?  @relation(fields: [clientId], references: [id])
  review      Review?

  @@index([barberId, startsAt])
  @@map("appointments")
}

model Expense {
  id             String   @id @default(cuid())
  barberId       String   @map("barber_id")
  description    String
  amountInCents  Int      @map("amount_in_cents")
  date           String   // "2025-01-15"
  createdAt      DateTime @default(now()) @map("created_at")
  barber         Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

model Review {
  id            String      @id @default(cuid())
  appointmentId String      @unique @map("appointment_id")
  barberId      String      @map("barber_id")
  clientId      String      @map("client_id")
  rating        Int         // 1-5
  comment       String      @default("")
  createdAt     DateTime    @default(now()) @map("created_at")
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  barber        Barber      @relation(fields: [barberId], references: [id])
  client        Client      @relation(fields: [clientId], references: [id])

  @@map("reviews")
}

model PasswordReset {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("password_resets")
}
