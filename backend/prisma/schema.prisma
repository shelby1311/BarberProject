generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  cpf          String   @unique
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  role         String   @default("client") // "client" | "barber"
  createdAt    DateTime @default(now()) @map("created_at")
  barber       Barber?
  client       Client?

  @@map("users")
}

model Client {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")
  phone  String @default("")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("clients")
}

model Barber {
  id           String         @id @default(cuid())
  userId       String         @unique @map("user_id")
  name         String
  location     String         @default("")
  slug         String         @unique
  bio          String         @default("")
  coverUrl     String         @default("") @map("cover_url")
  avatarUrl    String         @default("") @map("avatar_url")
  instagram    String         @default("")
  phone        String         @default("")
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  services     Service[]
  appointments Appointment[]
  gallery      GalleryImage[]
  workingHours WorkingHours[]

  @@map("barbers")
}

model Service {
  id              String        @id @default(cuid())
  barberId        String        @map("barber_id")
  name            String
  priceInCents    Int           @map("price_in_cents")
  durationMinutes Int           @map("duration_minutes")
  barber          Barber        @relation(fields: [barberId], references: [id], onDelete: Cascade)
  appointments    Appointment[]

  @@map("services")
}

model GalleryImage {
  id       String @id @default(cuid())
  barberId String @map("barber_id")
  url      String
  caption  String @default("")
  barber   Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@map("gallery_images")
}

model WorkingHours {
  id        String @id @default(cuid())
  barberId  String @map("barber_id")
  dayOfWeek Int    @map("day_of_week") // 0=Dom, 1=Seg ... 6=Sab
  startTime String @map("start_time") // "08:00"
  endTime   String @map("end_time")   // "18:00"
  barber    Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, dayOfWeek])
  @@map("working_hours")
}

model Appointment {
  id          String   @id @default(cuid())
  barberId    String   @map("barber_id")
  serviceId   String   @map("service_id")
  clientName  String   @map("client_name")
  startsAt    DateTime @map("starts_at")
  createdAt   DateTime @default(now()) @map("created_at")
  barber      Barber   @relation(fields: [barberId], references: [id])
  service     Service  @relation(fields: [serviceId], references: [id])

  @@index([barberId, startsAt])
  @@map("appointments")
}
